# OpenClaw Android .gitignore

# Built application files
*.apk
*.ap_
*.aab

# Files for the ART/Dalvik VM
*.dex

# Java class files
*.class

# Generated files
bin/
gen/
out/
release/

# Gradle files
.gradle/
build/

# Local configuration file (sdk path, etc)
local.properties

# Keystore files
*.jks
*.keystore
keystore.properties

# OS generated files
.DS_Store
Thumbs.db

# Android Studio Navigation editor temp files
.navigation/

# Android Studio captures folder
captures/

# IntelliJ
*.iml
.idea/
.idea/workspace.xml
.idea/tasks.xml
.idea/gradle.xml
.idea/assetWizardSettings.xml
.idea/dictionaries
.idea/libraries
.idea/caches
.idea/modules.xml
.idea/misc.xml

# External native build folder generated in Android Studio 2.2 and later
.externalNativeBuild
.cxx/

# Version control
vcs.xml

# lint
lint/intermediates/
lint/generated/
lint/outputs/
lint/tmp/

# Android Profiling
*.hprof

# Misc
*.swp
*.swo
*~

# Log files
*.log

# Secret files
.env
.secrets/

# Screenshots (optional, uncomment to ignore)
# screenshots/
