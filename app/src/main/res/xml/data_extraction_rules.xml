<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- 禁止备份敏感数据到云端 -->
        <exclude domain="sharedpref" path="secure_preferences.xml" />
        <exclude domain="database" path="conversations.db" />
        <exclude domain="file" path="models" />
    </cloud-backup>
    
    <device-transfer>
        <!-- 设备迁移时排除敏感数据 -->
        <exclude domain="sharedpref" path="secure_preferences.xml" />
        <exclude domain="database" path="conversations.db" />
    </device-transfer>
</data-extraction-rules>
